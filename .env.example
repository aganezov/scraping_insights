# Real YouTube collection
YOUTUBE_API_KEY=

# Optional Reddit API mode
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="insight-mine/0.2 (by u/yourname)"

# Free transcript defaults
YTTI_SKIP_PAID=1
YTTI_FREE_TIMEOUT_SEC=10

# Optional manual output override
# IM_OUT_DIR=/absolute/path/to/out

# Needed only if you explicitly choose Reddit scrape mode
# ALLOW_SCRAPING=1

# Optional paid transcript fallback for manual ad hoc runs
# YTTI_API_TOKEN=
